{
    "suggest.completionItemKindLabels": {
        "method": "\uea8c",
        "function": "\uea8c",
        "variable": "\uea88",
        "field": "\ueb5f",
        "typeParameter": "\uea92",
        "constant": "\ueb5d",
        "class": "\ueb5b",
        "interface": "\ueb61",
        "struct": "\uea91",
        "event": "",
        "operator": "\ueb64",
        "module": "󰅩",
        "property": "\ueb65",
        "enum": "\uea95",
        "reference": " ",
        "keyword": "\ueb62",
        "file": "\uf15b",
        "folder": "\ue6ad",
        "color": "\ue22b",
        "unit": "\uea96",
        "snippet": "\ueb66",
        "text": "\uea93",
        "constructor": "\uea8c",
        "value": "\uea90",
        "enumMember": "\ueb5b",
        "default": "\ueb63",
    },
    "clangd.arguments": ["--query-driver=/usr/bin/c++"],
    "diagnostic.virtualText": false,
    "diagnostic.enableHighlightLineNumber": true,
    "diagnostic.errorSign": "✘",
    "diagnostic.warningSign": " ",
    "diagnostic.infoSign": "",
    "diagnostic.hintSign": " ",
    "codeLens.enable": true,
    "signature.enable": true,
    "signature.floatConfig": {"highlight": "CocFloating",
                              "border": true, "rounded": true},
    "snippets.ultisnips.pythonPrompt": false,
    "snippets.extends": {"cpp": ["c"], "c": ["ctemplate"]},
    "snippets.userSnippetsDirectory": "${userHome}/.config/nvim/snippets",
    "git.enableGutters": true,
    "hover.floatConfig": {"border": true, "rounded": true},
    "suggest.autoTrigger": "always",
    "suggest.floatConfig": {"border": true, "rounded": true},
    "suggest.highPrioritySourceLimit": 10,
    "suggest.languageSourcePriority": 95,
    "suggest.lowPrioritySourceLimit": 90,
    "suggest.triggerCompletionWait": 30,
    "suggest.localityBonus": true,
    "suggest.enablePreselect": true,
    "suggest.removeDuplicateItems": true,
    "suggest.preferCompleteThanJumpPlaceholder": true,
    "suggest.defaultSortMethod": "alphabetical",
    "suggest.triggerAfterInsertEnter": false,
    "suggest.detailField": "preview",
    "suggest.noselect": false,
    "coc.source.file.priority": 70,
    "coc.source.buffer.priority": 50,
    "coc.preferences.formatOnType": true,
    "inlayHint.display": false,
    "pyright.enable": true,
    "pyright.inlayHints.functionReturnTypes": true,
    "pyright.inlayHints.parameterTypes": true,
    "pyright.inlayHints.variableTypes": true,
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": false,
    "python.linting.flake8Enabled": true,
    "python.linting.flake8Path": "flake8",
    "python.linting.flake8Args": ["--config=${env:HOME}/setup.cfg"],
    "python.pythonPath": "usr/bin/python",
    "python.formatting.provider": "autopep8",
    "python.formatting.blackPath": "~/.local/bin/autopep8",
    "clangd.path": "/usr/lib/llvm-19/bin/clangd",
    "clangd.disableProgressNotifications": false,
    "clangd.disableCompletion": false,
    "clangd.disableSnippetCompletion": false,
    "markdownlint.config": {
        "line_length": false
    },
    "semanticTokens.enable": true,
    "semanticTokens.incrementTypes": ["variable", "string", "parameter"],
    "yaml.format.enable": true,
    "links.tooltip": true,
    "lightbulb.text": { "default": "󰌵", "quickfix": "󰁨"},
    "outline.autoPreview": true,
    "outline.keepWindow": true
}
